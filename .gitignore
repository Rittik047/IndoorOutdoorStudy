# Generated outputs (models, plots, lag results, merged CSV)
output/models/*
output/plots/*
output/metrics/*
data/lag_results/*
!output/models/.gitkeep
!output/plots/.gitkeep
!output/metrics/.gitkeep
!data/lag_results/.gitkeep

